# Kopiere diese Datei als ".env" und trage deine API-Keys ein:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)

# OpenAI API-Key (benötigt für alle Samples)
# Registrieren: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-dein-openai-api-key-hier

# Serper API-Key (nur für Sample 2b - Web-Suche)
# Kostenlos registrieren (2500 Suchen gratis): https://serper.dev
SERPER_API_KEY=dein-serper-api-key-hier

# Telemetrie deaktivieren (verhindert Verbindungsfehler)
OTEL_SDK_DISABLED=true
